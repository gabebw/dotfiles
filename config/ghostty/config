# https://ghostty.org/docs/config
# The configuration can be reloaded at runtime by pressing cmd+shift+, (macOS).
# These are the default keybindings, but it is possible to define your own via the reload_config action.

# To see a list of available themes, run ghostty +list-themes
theme = Dracula
confirm-close-surface = false
# 22 lines
quick-terminal-size = 100px
# "NF" = "Nerd Font"
font-family = Maple Mono NF
font-size = 12

# https://ghostty.org/docs/config/keybind/reference
# "cmd" must be lowercase, not "Cmd"

# Cmd+k triggers a command palette, like VS Code
keybind = cmd+k=toggle_command_palette

# Turn off fullscreen keybinding (Ctrl-cmd-f)
# To make it fullscreen: Cmd-k, then "Toggle full screen"
fullscreen = false

# no-attention: don't badge the icon in the dock when there's a bell
bell-features = no-attention
